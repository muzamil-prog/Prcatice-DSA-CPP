#include<iostream>
#include<vector>
using namespace std;

vector<int> graph[100];
bool visited[100];

void dfs(int node){

    visited[node]=true;

    cout<<node<<" ";

    for(int child:graph[node]){

        if(!visited[child])
            dfs(child);

    }

}

int main(){

    graph[1].push_back(2);
    graph[1].push_back(3);

    graph[2].push_back(4);
    graph[2].push_back(5);

    dfs(1);

}